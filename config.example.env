# Gong API Configuration
# Copy this file to .env and fill in your actual values

# Your Gong API Access Key
GONG_ACCESS_KEY=your_access_key_here

# Your Gong API Access Key Secret
GONG_ACCESS_KEY_SECRET=your_access_key_secret_here

# Optional: Custom Gong API base URL (default: https://api.gong.io/v2)
# GONG_BASE_URL=https://api.gong.io/v2